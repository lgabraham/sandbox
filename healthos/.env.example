# ---------------------------------------------------------------------------
# HealthOS environment configuration
# Copy to .env and fill in. Never commit the real .env.
#
# NOTE: keep comments on their OWN lines. An inline comment after an *empty*
# value (e.g. `KEY=   # note`) gets read as the literal value by the .env parser.
# ---------------------------------------------------------------------------

# Database
DATABASE_URL=postgresql+psycopg://healthos:healthos@localhost:5432/healthos

# Whoop
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8000/auth/whoop/callback
# Filled in automatically after the first OAuth flow; leave blank.
WHOOP_ACCESS_TOKEN=
WHOOP_REFRESH_TOKEN=

# Garmin (via garth). garth handles the session internally from email/password.
GARMIN_EMAIL=
GARMIN_PASSWORD=
# Optional: path to a saved garth session dir. Leave blank to log in fresh.
GARMIN_TOKENSTORE=

# Eight Sleep
EIGHT_SLEEP_EMAIL=
EIGHT_SLEEP_PASSWORD=
# Optional: override the mobile app's public OAuth client (only if rotated).
EIGHT_SLEEP_CLIENT_ID=
EIGHT_SLEEP_CLIENT_SECRET=

# App
TIMEZONE=America/Los_Angeles
# Local hour (0-23) to run the nightly sync via the in-process scheduler.
SYNC_HOUR=6
PORT=8000
# Set false when an external cron runs `healthos sync` (avoids double-syncing).
ENABLE_SCHEDULER=true

# Comma-separated origins allowed to call the API (the dashboard).
CORS_ORIGINS=http://localhost:5173
