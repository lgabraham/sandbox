# ---------------------------------------------------------------------------
# HealthOS environment configuration
# Copy to .env and fill in. Never commit the real .env.
# ---------------------------------------------------------------------------

# Database -----------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://healthos:healthos@localhost:5432/healthos

# Whoop --------------------------------------------------------------------
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8000/auth/whoop/callback
WHOOP_ACCESS_TOKEN=        # stored after first OAuth flow
WHOOP_REFRESH_TOKEN=

# Garmin (via garth) -------------------------------------------------------
GARMIN_EMAIL=
GARMIN_PASSWORD=           # garth handles session internally
GARMIN_TOKENSTORE=         # optional path to a saved garth session dir

# Eight Sleep --------------------------------------------------------------
EIGHT_SLEEP_EMAIL=
EIGHT_SLEEP_PASSWORD=

# App ----------------------------------------------------------------------
TIMEZONE=America/Los_Angeles
SYNC_HOUR=6                # local hour to run nightly sync
PORT=8000

# Optional: comma-separated origins allowed to call the API (the dashboard).
CORS_ORIGINS=http://localhost:5173
